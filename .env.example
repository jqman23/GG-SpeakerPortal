GROQ_API_KEY=your_groq_api_key_here

# Google Apps Script Web App deployment URL that appends survey submissions
# to a Google Sheet in real time. See apps-script/survey-sheet-sync.gs.
SHEET_SYNC_URL=https://script.google.com/macros/s/your-deployment-id/exec
# Must match the SHARED_SECRET Script Property set in the Apps Script project.
SHEET_SYNC_SECRET=a-long-random-string
